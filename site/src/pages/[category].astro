---
import { getAllSections } from '../lib/readme';
import '../styles/global.css';

export function getStaticPaths() {
  return getAllSections().map(({ slug, title, html }) => ({
    params: { category: slug },
    props: { title, html },
  }));
}

const { category } = Astro.params;
const { title, html } = Astro.props;

const SITE_URL = 'https://samber.github.io/awesome-user-research/';
const BASE = '/awesome-user-research/';
const canonicalUrl = `${SITE_URL}${category}/`;

// Per-category SEO metadata targeting real search queries.
const META: Record<string, { pageTitle: string; description: string }> = {
  'all-in-one-platforms': {
    pageTitle: 'Best All-in-One User Research Platforms (2026) | Awesome User Research',
    description:
      'Compare all-in-one product research platforms: Contentsquare, Datadog, Hotjar, Pendo, PostHog, and Screeb — combining session replay, analytics, surveys, and feature flags in one tool.',
  },
  'survey': {
    pageTitle: 'Best Survey & Feedback Tools for Product Teams (2026) | Awesome User Research',
    description:
      'Curated list of survey and feedback tools for PMs and UX researchers: in-app surveys (Sprig, Refiner, PostHog), feedback analysis (Enterpret, Dovetail, Thematic), and NPS tools.',
  },
  'product-discovery': {
    pageTitle: 'Product Discovery Tools — Canny, Productboard, Harvestr | Awesome User Research',
    description:
      'Tools for capturing, organizing, and prioritizing product feedback: Canny, Productboard, and Harvestr to close the loop between user insights and product decisions.',
  },
  'session-recording': {
    pageTitle: 'Best Session Recording & Heatmap Tools (2026) | Awesome User Research',
    description:
      'Compare session recording and heatmap tools: Hotjar, Fullstory, Microsoft Clarity, PostHog, Smartlook, Heap, and Contentsquare for understanding how users interact with your product.',
  },
  'analytics': {
    pageTitle: 'Best Product & Marketing Analytics Tools (2026) | Awesome User Research',
    description:
      'Curated list of analytics tools for product and marketing teams: product analytics (Amplitude, Mixpanel, PostHog), marketing analytics (Google Analytics), BI (Metabase, Looker), and CDPs (Segment).',
  },
  'feature-flags--experimentation': {
    pageTitle: 'Best Feature Flag & A/B Testing Tools (2026) | Awesome User Research',
    description:
      'Compare feature flag and experimentation platforms: LaunchDarkly, PostHog, GrowthBook, Optimizely, Split.io, VWO, and Flagsmith for controlled rollouts and data-driven experiments.',
  },
  'product-tours--onboarding': {
    pageTitle: 'Best Product Tour & User Onboarding Tools (2026) | Awesome User Research',
    description:
      'Tools for building in-app product tours and onboarding flows: Appcues, Pendo, Intercom, and Screeb to drive activation and reduce time-to-value.',
  },
  'user-testing': {
    pageTitle: 'Best User Testing Tools (2026) — Maze, UserTesting, Sprig | Awesome User Research',
    description:
      'Platforms for unmoderated and moderated usability testing: Maze, UserTesting, and Sprig to validate designs and flows with real users before shipping.',
  },
  'user-interview': {
    pageTitle: 'Best User Interview Tools (2026) — Grain, Dovetail, Lookback | Awesome User Research',
    description:
      'Tools for conducting, recording, and analyzing user interviews: Grain, Lookback, Great Question, Lyssna, Discuss, and Outset for qualitative research at scale.',
  },
  'research-repository': {
    pageTitle: 'Best Research Repository Tools — Dovetail, Condens, Marvin | Awesome User Research',
    description:
      'Centralize and organize research artifacts with Dovetail, Condens, and Marvin — AI-powered repositories for tagging, theming, and surfacing insights across studies.',
  },
  'user-recruitment': {
    pageTitle: 'Best User Research Recruitment Tools (2026) | Awesome User Research',
    description:
      'Recruit the right research participants fast with Prolific, Respondent, and User Interviews — covering B2B, consumer, and niche audience panels.',
  },
  'learn': {
    pageTitle: 'UX Research Learning Resources — Books, Podcasts, Events | Awesome User Research',
    description:
      'Curated learning resources for UX researchers and product managers: books (The Mom Test, Continuous Discovery Habits), podcasts (Awkward Silences), events, blogs, and people to follow.',
  },
};

const meta = META[category] ?? {
  pageTitle: `${title} | Awesome User Research`,
  description: `Curated list of ${title} tools and resources for product managers and UX researchers.`,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: meta.pageTitle,
  description: meta.description,
  url: canonicalUrl,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', url: SITE_URL, name: 'Awesome User Research' },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Awesome User Research', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: title, item: canonicalUrl },
    ],
  },
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.pageTitle}</title>
    <meta name="description" content={meta.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    <link rel="sitemap" type="application/xml" href={`${BASE}sitemap.xml`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Awesome User Research" />
    <meta property="og:title" content={meta.pageTitle} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${SITE_URL}og-image.svg`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@samuelberthe" />
    <meta name="twitter:title" content={meta.pageTitle} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={`${SITE_URL}og-image.svg`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="hero" style="padding: 2.5rem 1rem;">
      <div class="hero-inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={BASE}>Awesome User Research</a>
          <span aria-hidden="true"> › </span>
          <span>{title}</span>
        </nav>
        <h1 class="hero-title" style="margin-top: 0.75rem;">
          <span class="hero-title-main">{title}</span>
        </h1>
        <p class="hero-desc">{meta.description}</p>
        <div class="hero-actions" style="margin-top: 1.25rem;">
          <a href={BASE} class="hero-cta" style="font-size: 0.875rem;">
            ← Back to full list
          </a>
        </div>
      </div>
    </div>

    <main class="content">
      <Fragment set:html={html} />
    </main>
  </body>
</html>

<style>
  .breadcrumb {
    font-size: 0.875rem;
    color: var(--muted-on-dark);
  }
  .breadcrumb a {
    color: var(--muted-on-dark);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--text-on-dark);
    text-decoration: underline;
  }
</style>
